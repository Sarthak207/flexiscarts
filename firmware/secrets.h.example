/*
  secrets.h.example
  ------------------
  Copy this file to secrets.h (same folder) and fill in real values.
  secrets.h is in .gitignore and must NEVER be committed.

  This directly fixes the Phase 1 finding that Wi-Fi credentials and
  Firebase auth were compiled in plaintext directly into
  smartcart_esp32.ino, visible to anyone who opened the source file (and
  extractable from the compiled binary regardless of which file they lived
  in -- see the note in smartcart_esp32.ino about physical-access risk,
  which secrets.h does not itself solve, only the source-control exposure).
*/

#ifndef SMARTCART_SECRETS_H
#define SMARTCART_SECRETS_H

#define WIFI_SSID       "YOUR_WIFI_SSID"
#define WIFI_PASSWORD   "YOUR_WIFI_PASSWORD"

// Backend host/port -- the Raspberry Pi 4's LAN IP or hostname, since the
// backend runs on the Pi itself (docker-compose) per the chosen
// single-box architecture. Use a static DHCP reservation or mDNS hostname
// for the Pi so this doesn't need updating if its IP changes.
#define BACKEND_HOST    "192.168.1.50"
#define BACKEND_PORT    8000

// Must match DEVICE_API_KEY in the backend's .env exactly.
#define DEVICE_API_KEY  "YOUR_DEVICE_API_KEY"

// Which physical cart this firmware belongs to -- matches the cart_id
// used by the touchscreen UI when it calls POST /sessions/start.
#define CART_ID         "cart-01"

// Optional: OTA update password (see ArduinoOTA section in the .ino).
#define OTA_PASSWORD    "YOUR_OTA_PASSWORD"

#endif
